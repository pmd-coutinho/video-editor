{
  "name": "my-tanstack-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --check package.json tsconfig.json vite.config.ts eslint.config.js playwright.config.ts src tests",
    "format:write": "prettier --write package.json tsconfig.json vite.config.ts eslint.config.js playwright.config.ts src tests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --passWithNoTests --exclude tests/browser/**",
    "test:browser": "pnpm build && playwright test"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.28",
    "@tanstack/router-plugin": "1.168.20",
    "lucide-react": "0.545.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/router-cli": "1.167.19",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "jsdom": "28.1.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
